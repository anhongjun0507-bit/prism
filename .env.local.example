# PRISM 환경변수 — .env.local로 복사 후 실제 값 입력
# Production 배포는 호스팅 환경(Vercel/Firebase Hosting 등)의 secret manager 사용

# ─── Anthropic Claude API ───
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Firebase 클라이언트 SDK (NEXT_PUBLIC_*는 브라우저에 노출됨) ───
# Firebase Console → 프로젝트 설정 → 일반 → 내 앱
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=prism-app-3ab7d
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin SDK (서버 전용 — 결제/카카오/API 인증) ───
# Firebase Console → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
FIREBASE_ADMIN_PROJECT_ID=prism-app-3ab7d
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-...@prism-app-3ab7d.iam.gserviceaccount.com
# private key는 한 줄에 작성, 개행은 \n 이스케이프
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Toss Payments (결제) ───
# https://app.tosspayments.com/
TOSS_SECRET_KEY=test_sk_...
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...

# ─── 카카오 OAuth (선택) ───
# https://developers.kakao.com/console/app
NEXT_PUBLIC_KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ─── Google Analytics (선택) ───
# 값이 없으면 Analytics 컴포넌트는 consent 배너까지 렌더하지 않음.
NEXT_PUBLIC_GA_ID=

# ─── Sentry (선택, 에러 트래킹) ───
# DSN 비어 있으면 sentry.client/server/edge.config.ts에서 init이 no-op으로 처리됨.
# https://sentry.io/settings/[org]/projects/[project]/keys/
NEXT_PUBLIC_SENTRY_DSN=
# 소스맵 업로드용 (CI 빌드 시에만 필요; 로컬은 비워둬도 됨)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── 마스터 계정 (운영진 — 모든 plan 한도 우회) ───
# 서버 전용. 쉼표 구분 이메일 목록. 빈 값이면 마스터 없음.
# 이전 NEXT_PUBLIC_MASTER_EMAILS 지양 — 클라이언트 번들에 이메일 목록이 노출됨.
MASTER_EMAILS=admin@example.com,owner@example.com
