rules_version = '2';

// PRISM Firestore 보안 규칙
// 배포: firebase deploy --only firestore:rules
//
// 핵심 원칙:
// 1. 기본은 deny — 명시적으로 허용된 경로만 접근 가능
// 2. 사용자 데이터는 본인만 read/write (request.auth.uid == uid)
// 3. 결제·플랜 필드는 클라이언트가 못 씀 (서버 Admin SDK 전용)
//    → 클라이언트가 플랜을 임의로 'premium'으로 변경 못함
// 4. admission_results는 익명 공개 피드 (인증 사용자만 read/create, update/delete 금지)
service cloud.firestore {
  match /databases/{database}/documents {

    /* ──────────────────────────────────────────────────────────
       사용자 프로필: users/{uid}
       ──────────────────────────────────────────────────────── */

    // 결제·플랜·쿼터 보호 필드 — 클라이언트가 직접 수정 불가 (서버 Admin SDK 전용)
    //
    // - plan: 무료→프리미엄 우회 차단 (서버 /api/match가 plan을 신뢰함)
    // - planBilling/planActivatedAt/lastPayment: 결제 감사 트레일 위변조 차단
    // - usage: 서버 enforceQuota()가 신뢰하는 쿼터 카운터.
    //   클라가 reset하면 일일 한도(예: aiChat 5회)가 무한으로 풀림 → Claude API 과금.
    //   chat 페이지의 aiChatCount/aiChatDate(UI 표시용 별도 필드)와 다르니 혼동 주의.
    //
    // 마스터 계정·신규 회원가입은 plan을 Firestore에 쓰지 않도록 클라이언트 코드에서 우회
    // (auth-context에서 saveProfile 시 plan 필드 strip)
    function touchesProtectedFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['plan', 'planBilling', 'planActivatedAt', 'lastPayment', 'usage']);
    }

    function createIncludesProtectedFields() {
      return request.resource.data.keys()
        .hasAny(['plan', 'planBilling', 'planActivatedAt', 'lastPayment', 'usage']);
    }

    match /users/{uid} {
      // 본인만 읽기 가능
      allow read: if request.auth != null && request.auth.uid == uid;

      // 신규 생성: 본인 + 보호 필드 미포함
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && !createIncludesProtectedFields();

      // 업데이트: 본인 + 보호 필드 변경 없음
      // (Admin SDK는 보안 규칙을 우회하므로 결제 confirm·카카오 callback은 영향 없음)
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && !touchesProtectedFields();

      // 삭제는 어떤 클라이언트도 못함 (계정 삭제는 서버 함수로 처리)
      allow delete: if false;

      /* ────────────────────────────
         레거시 에세이 단일 doc: users/{uid}/data/essays
         (서브컬렉션으로 마이그레이션 중. 마이그레이션 완료 후 read-only로 변경 가능)
         ──────────────────────────── */
      match /data/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      /* ────────────────────────────
         에세이 (per-essay 서브컬렉션): users/{uid}/essays/{essayId}
         per-record write로 race condition 방지
         ──────────────────────────── */
      match /essays/{essayId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      /* ────────────────────────────
         플래너 작업: users/{uid}/tasks/{taskId}
         ──────────────────────────── */
      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      /* ────────────────────────────
         AI 카운슬러 대화: users/{uid}/chat/{chatId}
         단일 doc(history)로 관리 — 로그아웃/다기기에서 맥락 복원.
         ──────────────────────────── */
      match /chat/{chatId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    /* ──────────────────────────────────────────────────────────
       익명 합격결과 피드: admission_results/{docId}
       ────────────────────────────────────────────────────────
       Week 5: 매칭·피드는 verified==true 문서만 노출.
        - 시드 데이터(스태프 검수 완료)는 verified:true + source:"partner"
        - 사용자 자가 제출본은 verified:false로 강제 (운영자가 수동 검증)
        - 클라이언트는 verified:true 문서만 read 가능
        - Admin SDK(서버 API)는 규칙 우회 → 챗봇 RAG는 unverified 포함 가능
       ────────────────────────────────────────────────────────── */
    match /admission_results/{docId} {
      // 읽기: 로그인 + verified==true만 노출 (매칭·피드 공통 규칙)
      allow read: if request.auth != null
                  && resource.data.verified == true;

      // 생성: 로그인 + 데이터 구조 검증 + verified:false 강제 (자가 검증 차단)
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['results', 'submittedAt', 'year', 'verified'])
                    && request.resource.data.verified == false
                    && request.resource.data.results is list
                    && request.resource.data.results.size() > 0
                    && request.resource.data.results.size() <= 30
                    && request.resource.data.submittedAt is string
                    && request.resource.data.submittedAt.size() <= 40
                    && request.resource.data.year is number
                    && request.resource.data.year >= 2020
                    && request.resource.data.year <= 2035;

      // 익명 데이터는 수정·삭제 불가 (한 번 제출하면 영구)
      allow update, delete: if false;
    }

    /* ──────────────────────────────────────────────────────────
       합격 사례 AI 분석 캐시: admission_analysis_cache/{matchId__profileHash}
       서버 Admin SDK 전용 — 클라이언트 접근 금지.
       ────────────────────────────────────────────────────────── */
    match /admission_analysis_cache/{cacheId} {
      allow read, write: if false;
    }

    /* ──────────────────────────────────────────────────────────
       결제 기록: payments/{orderId}
       서버 Admin SDK 전용 — 클라이언트 직접 접근 완전 차단.
       (멱등성·감사·환불 분쟁 시 진실의 단일 출처)
       ──────────────────────────────────────────────────────── */
    match /payments/{orderId} {
      allow read, write: if false;
    }

    /* ──────────────────────────────────────────────────────────
       학부모 view-only 토큰: parent_view_tokens/{token}
       ────────────────────────────────────────────────────────
       학생이 발급한 view-only 링크. 학부모는 로그인 없이 /parent-view/{token}로 접근.
       클라이언트(학생)는 본인 토큰만 read/list/revoke 가능. 발급은 서버 API 경유 권장
       (서버 Admin SDK가 plan 검증·active count cap·viewLimit 강제).

       클라이언트 발급 분기는 Rules로 초기 invariants(viewCount=0, revoked=false)만 체크하고
       나머지(plan, active count cap)는 거부할 수 없다. 그러므로 /api/parent/tokens 경유 권장.

       서버 Admin SDK는 이 Rules를 우회하므로 viewCount/lastViewedAt 자유 갱신 가능.
       /parent-view/[token] Server Component도 Admin SDK 사용 → 학부모는 인증 없이 접근.
       ──────────────────────────────────────────────────────── */
    match /parent_view_tokens/{tokenId} {
      // 학생 본인만 자기 토큰 조회/리스트
      allow read: if request.auth != null
                  && resource.data.studentUid == request.auth.uid;

      // 생성: 본인 uid + 초기값 invariants 검증
      // (실제 발급은 서버 /api/parent/tokens 권장 — plan·active count cap 적용)
      allow create: if request.auth != null
                    && request.resource.data.studentUid == request.auth.uid
                    && request.resource.data.viewCount == 0
                    && request.resource.data.revoked == false;

      // 업데이트: 학생은 revoked만 변경 가능 (다른 필드 변경 차단)
      // viewCount/lastViewedAt 등은 서버 Admin SDK 전용.
      allow update: if request.auth != null
                    && resource.data.studentUid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['revoked']);

      // 직접 삭제 불가 — revoke만 (감사 트레일 유지)
      allow delete: if false;
    }

    /* ──────────────────────────────────────────────────────────
       기본 deny — 명시되지 않은 모든 경로는 차단
       ──────────────────────────────────────────────────────── */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
